{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "jsx": "preserve",
    "esModuleInterop": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": [
    "nuxt.config.ts",
    "plugins/**/*.ts",
    "server/**/*"
  ]
}
